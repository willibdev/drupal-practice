# Ignore files generated by the IDE
/.idea/
/.vscode/

# Ignore FE dependencies
node_modules

# Ignore directories generated by Composer
/drush/contrib/
/vendor/
/web/core/
/web/modules/contrib/
/web/themes/contrib/
/web/profiles/contrib/
/web/libraries/

# Ignore local settings overrides.
/web/sites/*/*.local.*

# Ignore Drupal's file directory
/web/sites/*/files/

# Ignore .env files as they are personal
/.env

# Prevent private files from being committed.
/private
!/private/.gitkeep
